# ==========================================
# GEMACHT ENVIRONMENT CONFIGURATION TEMPLATE
# ==========================================

# ── Backend Configuration ──
# Port on which the express backend server runs
PORT=3001

# Allowed client origin for CORS restriction
CLIENT_ORIGIN=http://localhost:5173

# Music recognition provider. Options: 'mock' or 'acrcloud'
# Use 'mock' for local development and testing without paid credentials.
MUSIC_RECOGNITION_PROVIDER=mock

# ── ACRCloud API Credentials ──
# Required ONLY when MUSIC_RECOGNITION_PROVIDER=acrcloud
ACRCLOUD_HOST=identify-eu-west-1.acrcloud.com
ACRCLOUD_ACCESS_KEY=your_access_key_here
ACRCLOUD_ACCESS_SECRET=your_access_secret_here

# ── Frontend Configuration (Vite) ──
# (If building client separate or exposing variables)
VITE_API_URL=http://localhost:3001
